{
  "compilerOptions": {
    "target": "ES2020",

    "module": "commonjs",
    "moduleResolution": "node",

    "lib": ["ES2020"],

    "rootDir": "..",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "baseUrl": ".",

    "paths": {
      "@shared/*": ["../shared/*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src/**/*",
    "../shared/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}